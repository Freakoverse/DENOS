{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "DENOS",
    "version": "0.1.0",
    "identifier": "dnnid.denos.signer",
    "build": {
        "beforeDevCommand": "npm run dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "npm run build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "DENOS — Nostr Signer, Payment System, and ID Manager",
                "width": 460,
                "height": 780,
                "resizable": true,
                "decorations": false,
                "backgroundThrottling": "disabled",
                "dragDropEnabled": false
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": "all",
        "icon": [
            "icons/32x32.png",
            "icons/48x48.png",
            "icons/128x128.png",
            "icons/256x256.png",
            "icons/512x512.png",
            "icons/icon.png",
            "icons/icon.icns",
            "icons/icon.ico"
        ],
        "publisher": "DNN",
        "copyright": "© 2026 DNN",
        "shortDescription": "Nostr Signer, Payment System, and ID Manager",
        "longDescription": "DENOS is a Nostr signer, ID manager, and payment system.",
        "license": "MIT",
        "licenseFile": "LICENSE",
        "homepage": "https://denos.nabandonaread",
        "category": "Finance",
        "linux": {
            "deb": {
                "desktopTemplate": "denos.desktop.template",
                "section": "utils",
                "priority": "optional",
                "files": {
                    "/usr/share/metainfo/dnnid.denos.signer.metainfo.xml": "dnnid.denos.signer.metainfo.xml",
                    "/usr/share/icons/hicolor/128x128/apps/dnnid.denos.signer.png": "icons/128x128.png",
                    "/usr/share/icons/hicolor/256x256/apps/dnnid.denos.signer.png": "icons/256x256.png",
                    "/usr/share/icons/hicolor/512x512/apps/dnnid.denos.signer.png": "icons/512x512.png",
                    "/usr/share/doc/denos/copyright": "copyright"
                }
            }
        }
    }
}